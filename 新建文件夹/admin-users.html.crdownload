<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>用户管理</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
  <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght@400;500;600&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="./shared.css" />
</head>
<body>
  <div class="app-shell">
    <aside class="app-sidebar">
      <div class="brand-box"><div class="brand-icon"><span class="material-symbols-outlined">admin_panel_settings</span></div><div><h1 class="brand-title">Admin Console</h1><p class="brand-subtitle">系统管理入口</p></div></div>
      <button class="sidebar-primary-cta"><span class="material-symbols-outlined">person_add</span>新增用户</button>
      <nav class="sidebar-nav">
        <a class="nav-item" href="./admin.html"><span class="material-symbols-outlined">grid_view</span><span>管理首页</span></a>
        <a class="nav-item active" href="./admin-users.html"><span class="material-symbols-outlined">group</span><span>用户管理</span></a>
        <a class="nav-item" href="./admin-roles.html"><span class="material-symbols-outlined">badge</span><span>角色管理</span></a>
        <a class="nav-item" href="./admin-logs.html"><span class="material-symbols-outlined">receipt_long</span><span>审计日志</span></a>
        <a class="nav-item" href="./admin-system.html"><span class="material-symbols-outlined">settings</span><span>系统配置</span></a>
      </nav>
      <div class="sidebar-bottom">
        <a class="nav-item" href="./dashboard.html"><span class="material-symbols-outlined">arrow_back</span><span>返回主系统</span></a>
      </div>
    </aside>
    <header class="app-topbar"><div class="topbar-left"><div><h2 class="topbar-title">用户管理</h2><div class="topbar-breadcrumb"><span>后台管理</span><span>/</span><span>用户管理</span></div></div></div></header>
    <main class="app-content">
      <div class="page-stack">
        <div class="page-header"><div><h1 class="page-title">用户管理</h1><p class="page-subtitle">用户增删改查页采用玻璃表格容器，但表格可读性优先于装饰。</p></div><div class="page-actions"><button class="btn-secondary">导入用户</button><button class="btn-primary">新增用户</button></div></div>
        <section class="admin-table-card glass-panel">
          <div class="admin-toolbar">
            <label class="search-shell"><span class="material-symbols-outlined">search</span><input type="text" placeholder="搜索姓名、部门、邮箱..." /></label>
            <div class="table-chip-group"><button class="btn-chip active">全部</button><button class="btn-chip">管理员</button><button class="btn-chip">普通用户</button></div>
          </div>
          <table class="data-table">
            <thead><tr><th>姓名</th><th>邮箱</th><th>部门</th><th>平台角色</th><th>状态</th><th>加入时间</th><th>操作</th></tr></thead>
            <tbody>
              <tr><td>张工</td><td>zhang@example.com</td><td>研发中心</td><td>user</td><td><span class="pill pill-success">正常</span></td><td>2026-04-01</td><td>编辑 / 停用</td></tr>
              <tr><td>系统管理员</td><td>admin@example.com</td><td>平台组</td><td>admin</td><td><span class="pill pill-success">正常</span></td><td>2026-01-01</td><td>编辑</td></tr>
              <tr><td>李技术员</td><td>li@example.com</td><td>测试组</td><td>user</td><td><span class="pill pill-warning">待激活</span></td><td>2026-04-15</td><td>激活</td></tr>
            </tbody>
          </table>
        </section>
      </div>
    </main>
  </div>
</body>
</html>
